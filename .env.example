# ===========================================
# Ship Pro - متغيرات البيئة المطلوبة
# ===========================================
# انسخ هذا الملف إلى .env وأضف قيمك الفعلية
# Copy this file to .env and fill in your values

# Supabase Configuration
# اذهب إلى: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# Application Settings
VITE_APP_NAME=ShipPro
VITE_APP_ENV=production

# ===========================================
# GitHub Actions Secrets (للنشر التلقائي)
# ===========================================
# أضف هذه المتغيرات في: GitHub → Settings → Secrets and variables → Actions
#
# VITE_SUPABASE_URL       = رابط مشروع Supabase
# VITE_SUPABASE_ANON_KEY  = مفتاح Supabase العام (anon key)
# VERCEL_TOKEN            = رمز Vercel (من: https://vercel.com/account/tokens)
# VERCEL_ORG_ID           = معرّف منظمة Vercel
# VERCEL_PROJECT_ID       = معرّف مشروع Vercel
# CLOUDFLARE_API_TOKEN    = رمز Cloudflare API (اختياري - للنشر على Cloudflare)
# CLOUDFLARE_ACCOUNT_ID   = معرّف حساب Cloudflare (اختياري)
